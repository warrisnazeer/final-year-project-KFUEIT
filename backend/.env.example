# Copy this to .env and fill in your values

# HuggingFace API Key (free at huggingface.co)
# Without this, app uses keyword-only scoring (still works!)
HUGGINGFACE_API_KEY=hf_your_key_here

# Database — SQLite by default (no setup needed)
# For production PostgreSQL (Supabase), replace with:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./news_narrative.db

# Frontend URL for CORS (update when deployed)
FRONTEND_URL=http://localhost:5173
